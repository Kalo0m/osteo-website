---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const title = "Gilles Coutinho - Ostéopathe D.O. à Nantes | Cabinet d'Ostéopathie";
const description = "Gilles Coutinho, ostéopathe D.O. à Nantes depuis 2009. Spécialisé en ostéopathie du sport, pédiatrique, crânienne et prénatale. Consultations au 132 Route de Saint-Joseph, Nantes. Prenez rendez-vous en ligne.";
---

<Layout title={title} description={description}>
  <!-- Navigation -->
  <nav class="nav" role="navigation" aria-label="Navigation principale">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Accueil">
        Gilles Coutinho
        <span>Ostéopathe D.O.</span>
      </a>
      <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <ul class="nav-links" id="nav-links">
        <li><a href="#specialites">Spécialités</a></li>
        <li><a href="#a-propos">À propos</a></li>
        <li><a href="#temoignages">Avis</a></li>
        <li><a href="#infos">Infos pratiques</a></li>
        <li><a href="#contact">Contact</a></li>
        <li><a href="https://www.doctolib.fr/osteopathe/nantes/gilles-coutinho" target="_blank" rel="noopener noreferrer" class="nav-cta">Prendre RDV</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero -->
  <header class="hero" id="accueil">
    <div class="hero-content">
      <span class="hero-badge">Cabinet d'ostéopathie à Nantes</span>
      <h1>Votre <em>ostéopathe</em> à Nantes depuis 2009</h1>
      <hr class="hero-divider" />
      <p class="hero-subtitle">
        Gilles Coutinho, ostéopathe D.O., vous accompagne avec une approche personnalisée pour soulager vos douleurs et améliorer votre bien-être au quotidien.
      </p>
      <div class="hero-actions">
        <a href="https://www.doctolib.fr/osteopathe/nantes/gilles-coutinho" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          Prendre rendez-vous
        </a>
        <a href="tel:0251712580" class="btn btn-outline">
          02 51 71 25 80
        </a>
      </div>
    </div>
  </header>

  <!-- Spécialités -->
  <section class="section specialties" id="specialites" aria-labelledby="specialites-title">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Spécialités</p>
        <h2 id="specialites-title">Des soins adaptés à chaque patient</h2>
        <p>Une prise en charge complète et personnalisée, du nourrisson au sportif de haut niveau.</p>
        <hr class="section-divider" />
      </div>
      <div class="specialties-grid">
        <article class="specialty-card">
          <div class="specialty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          </div>
          <h3>Ostéopathie structurelle</h3>
          <p>Traitement des troubles musculo-squelettiques : douleurs de dos, cervicalgies, lombalgies, sciatiques et douleurs articulaires par des techniques douces et précises.</p>
        </article>
        <article class="specialty-card">
          <div class="specialty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Ostéopathie crânienne</h3>
          <p>Approche douce visant à rétablir l'équilibre crânio-sacré. Efficace contre les migraines, les troubles du sommeil, le stress et les tensions chroniques.</p>
        </article>
        <article class="specialty-card">
          <div class="specialty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3>Ostéopathie du sport</h3>
          <p>Diplôme universitaire en ostéopathie du sport (UBO). Prévention et traitement des blessures sportives, optimisation de la performance et récupération.</p>
        </article>
        <article class="specialty-card">
          <div class="specialty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6"/><path d="M12 9v6"/><circle cx="12" cy="12" r="10"/></svg>
          </div>
          <h3>Ostéopathie pédiatrique</h3>
          <p>Prise en charge adaptée aux nourrissons et enfants : coliques, troubles du sommeil, torticolis congénital, plagiocéphalie et suivi de croissance.</p>
        </article>
        <article class="specialty-card">
          <div class="specialty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Ostéopathie prénatale</h3>
          <p>Accompagnement de la femme enceinte tout au long de la grossesse. Soulagement des douleurs lombaires, sciatiques et préparation du bassin à l'accouchement.</p>
        </article>
        <article class="specialty-card">
          <div class="specialty-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
          </div>
          <h3>Dysfonctions temporo-mandibulaires</h3>
          <p>Traitement des douleurs de la mâchoire, craquements, bruxisme et troubles de l'articulation temporo-mandibulaire (ATM) en collaboration avec votre dentiste.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- À propos -->
  <section class="section about" id="a-propos" aria-labelledby="apropos-title">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-image">
          <div class="about-image-placeholder">
            Photo de Gilles Coutinho<br/>
            <small>(à remplacer par une photo professionnelle)</small>
          </div>
        </div>
        <div class="about-content">
          <p class="section-label">À propos</p>
          <h2 id="apropos-title">Gilles Coutinho, ostéopathe D.O.</h2>
          <hr class="section-divider" style="margin: 0 0 1.5rem;" />
          <p class="about-text">
            Diplômé de l'Institut des Hautes Études Ostéopathiques de Nantes (IdHEO) en 2009, Gilles Coutinho exerce l'ostéopathie avec passion et rigueur depuis plus de 15 ans.
          </p>
          <p class="about-text">
            Titulaire d'un Diplôme Universitaire en Ostéopathie du Sport délivré par l'Université de Bretagne Occidentale (2011), il complète son approche par une formation continue permanente pour offrir à ses patients les meilleurs soins possibles.
          </p>
          <p class="about-text">
            Son cabinet, situé au sein d'un pôle pluridisciplinaire, favorise le dialogue interprofessionnel au service de votre santé. Chaque consultation est unique, avec un traitement personnalisé adapté à vos besoins.
          </p>
          <div class="about-details">
            <div class="about-detail">
              <div class="about-detail-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>
              </div>
              <div>
                <strong>Formation</strong>
                <span>D.O. IdHEO Nantes<br/>D.U. Sport (UBO)</span>
              </div>
            </div>
            <div class="about-detail">
              <div class="about-detail-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div>
                <strong>Expérience</strong>
                <span>En exercice depuis 2009</span>
              </div>
            </div>
            <div class="about-detail">
              <div class="about-detail-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div>
                <strong>Langues</strong>
                <span>Français, Anglais,<br/>Espagnol, Portugais</span>
              </div>
            </div>
            <div class="about-detail">
              <div class="about-detail-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <strong>Cabinet</strong>
                <span>Pôle pluridisciplinaire</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="section testimonials" id="temoignages" aria-labelledby="temoignages-title">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Témoignages</p>
        <h2 id="temoignages-title">Ce que disent nos patients</h2>
        <p>La satisfaction de nos patients est notre priorité.</p>
        <hr class="section-divider" />
      </div>
      <div class="testimonials-grid">
        <article class="testimonial-card">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <div class="testimonial-stars" aria-label="5 étoiles sur 5">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial-text">Très sympathique, pédagogue et professionnel. Il a très vite cerné le problème pour lequel je venais le voir. Je suis enchanté ! Je le conseille.</p>
          <p class="testimonial-author">Patient sur osteopathe.do</p>
        </article>
        <article class="testimonial-card">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <div class="testimonial-stars" aria-label="5 étoiles sur 5">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial-text">L'un des meilleurs de la région, super pro, et tellement sympa ! Il a su directement ce que j'avais, alors que je suis passé par un chirurgien, kiné et autres ostéo.</p>
          <p class="testimonial-author">Patient sur Google</p>
        </article>
        <article class="testimonial-card">
          <div class="testimonial-quote" aria-hidden="true">&ldquo;</div>
          <div class="testimonial-stars" aria-label="5 étoiles sur 5">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial-text">Je suis allée voir Mr Coutinho trois fois pour l'instant. Je suis toujours ressortie soulagée et ravie. Prend son temps, te regarde de la tête aux pieds.</p>
          <p class="testimonial-author">Patiente sur osteopathe.do</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Infos pratiques -->
  <section class="section info" id="infos" aria-labelledby="infos-title">
    <div class="section-inner">
      <div class="section-header">
        <p class="section-label">Infos pratiques</p>
        <h2 id="infos-title">Tout ce qu'il faut savoir</h2>
        <p>Horaires, tarifs et modalités de consultation.</p>
        <hr class="section-divider" />
      </div>
      <div class="info-grid">
        <div class="info-card">
          <div class="info-card-icon" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Horaires</h3>
          <ul>
            <li><span>Lundi</span><span>8h - 20h</span></li>
            <li><span>Mardi</span><span>8h - 20h</span></li>
            <li><span>Mercredi</span><span>8h - 20h</span></li>
            <li><span>Jeudi</span><span>8h - 20h</span></li>
            <li><span>Vendredi</span><span>8h - 20h</span></li>
            <li><span>Samedi</span><span>8h - 13h</span></li>
            <li><span>Dimanche</span><span>Fermé</span></li>
          </ul>
        </div>
        <div class="info-card">
          <div class="info-card-icon" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M12 12h.01"/></svg>
          </div>
          <h3>Tarif</h3>
          <p class="price">65 &euro;</p>
          <p class="price-note">Consultation non conventionnée.<br/>Remboursement partiel possible par votre mutuelle.</p>
          <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--color-text-light);">
            <strong>Moyens de paiement :</strong><br/>
            Carte bancaire, chèque, espèces
          </p>
        </div>
        <div class="info-card">
          <div class="info-card-icon" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#2C5F4B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3>Accès</h3>
          <p><strong>Cabinet de Nantes</strong><br/>132 Route de Saint-Joseph<br/>44300 Nantes</p>
          <p style="margin-top: 1rem;"><strong>Cabinet de Château-Thébaud</strong><br/>35 Rue Saint-Thomas<br/>44690 Château-Thébaud</p>
          <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--color-text-light);">
            Plain-pied &middot; Accès PMR &middot; Parking gratuit
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="contact" aria-labelledby="contact-title">
    <div class="section-inner">
      <p class="section-label">Contact</p>
      <h2 id="contact-title">Prenez rendez-vous dès maintenant</h2>
      <p>Réservez votre consultation en ligne via Doctolib ou contactez le cabinet par téléphone.</p>
      <div class="hero-actions">
        <a href="https://www.doctolib.fr/osteopathe/nantes/gilles-coutinho" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          Réserver sur Doctolib
        </a>
        <a href="tel:0251712580" class="btn btn-outline">
          02 51 71 25 80
        </a>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map" aria-label="Localisation du cabinet">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2712.5!2d-1.5536!3d47.2184!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s132+Route+de+Saint-Joseph+44300+Nantes!5e0!3m2!1sfr!2sfr!4v1"
      title="Carte du cabinet d'ostéopathie Gilles Coutinho à Nantes"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen>
    </iframe>
  </section>

  <!-- Footer -->
  <footer class="footer" role="contentinfo">
    <div class="footer-inner">
      <div>
        <p class="footer-logo">Gilles Coutinho</p>
        <p>Ostéopathe D.O. à Nantes &middot; N° RPPS 10010524345</p>
      </div>
      <ul class="footer-links">
        <li><a href="#accueil">Accueil</a></li>
        <li><a href="#specialites">Spécialités</a></li>
        <li><a href="#a-propos">À propos</a></li>
        <li><a href="#contact">Contact</a></li>
        <li><a href="https://www.doctolib.fr/osteopathe/nantes/gilles-coutinho" target="_blank" rel="noopener noreferrer">Doctolib</a></li>
      </ul>
    </div>
  </footer>

  <script>
    // Mobile navigation toggle
    const toggle = document.querySelector('.nav-toggle');
    const navLinks = document.getElementById('nav-links');

    if (toggle && navLinks) {
      toggle.addEventListener('click', () => {
        const isOpen = navLinks.classList.toggle('active');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });

      // Close menu on link click
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navLinks.classList.remove('active');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // Smooth scroll with offset for fixed nav
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const targetId = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
        if (!targetId || targetId === '#') return;
        const target = document.querySelector(targetId);
        if (target) {
          e.preventDefault();
          const offset = 80;
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });
  </script>
</Layout>
